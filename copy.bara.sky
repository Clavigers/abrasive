core.workflow(
    name = "default",
    origin = git.origin(
        url = "https://github.com/Clavigers/abrasive.git",
        ref = "master",
    ),
    destination = git.github_destination(
        url = "https://github.com/Clavigers/abrasive-cli.git",
        push = "main",
    ),
    origin_files = glob(
        include = ["cli/**", "protocol/**"],
    ),
    authoring = authoring.pass_thru("William Murray <wmurra@users.noreply.github.com>"),
    transformations = [],
)
