---
interface Props {
  title: string;
  hideFooter?: boolean;
}
const { title, hideFooter = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style is:global>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      :root {
        --bg: #0d1117;
        --fg: #c9d1d9;
        --muted: #8b949e;
        --accent: #e8b931;
        --code-bg: #161b22;
        --border: #30363d;
      }
      html {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
        background: var(--bg);
        color: var(--fg);
      }
      body {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 2rem 2rem 0;
      }
      footer {
        margin-top: auto;
        width: 100vw;
        background: #090c10;
        border-top: 1px solid var(--border);
        padding: 2rem 2rem 0;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .footer-inner {
        display: flex;
        gap: 4rem;
        padding: 2rem 0;
        width: 100%;
        max-width: 1200px;
      }
      .footer-col {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .footer-col h4 {
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--fg);
        margin-bottom: 0.25rem;
      }
      .footer-col a {
        color: var(--muted);
        text-decoration: none;
        font-size: 0.85rem;
        transition: color 0.15s;
      }
      .footer-col a:hover {
        color: var(--fg);
      }
      .footer-bottom {
        border-top: 1px solid var(--border);
        padding: 1rem 0;
        font-size: 0.75rem;
        color: var(--muted);
        width: 100%;
        max-width: 1200px;
      }
    </style>
  </head>
  <body>
    <slot />
    {!hideFooter && (
      <footer>
        <div class="footer-inner">
          <div class="footer-col">
            <h4>Abrasive</h4>
            <a href="/">Home</a>
            <a href="/demo">Demo</a>
            <a href="/getting-started">Get Started</a>
          </div>
          <div class="footer-col">
            <h4>Install</h4>
            <a href="/get_abrasive">Get Abrasive</a>
            <a href="/getting-started#alias">Cargo Alias</a>
          </div>
          <div class="footer-col">
            <h4>Community</h4>
            <a href="https://github.com/wmurra/abrasive">GitHub</a>
            <a href="https://github.com/wmurra/abrasive/issues">Issues</a>
            <a href="https://github.com/wmurra/abrasive/discussions">Discussions</a>
          </div>
        </div>
        <div class="footer-bottom">
          <span>&copy; 2026 Claviger.</span>
        </div>
      </footer>
    )}
  </body>
</html>
