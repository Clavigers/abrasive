---
import { Image } from 'astro:assets';
import abrasiveLetters from '../AbrasiveLetters.png';
---
<header class="topbar">
  <div class="topbar-inner">
    <a href="/" class="brand" aria-label="abrasive">
      <Image src={abrasiveLetters} alt="abrasive" class="brand-img" />
    </a>
    <nav class="links">
      <a href="#">Features</a>
      <a href="#">Pricing</a>
      <a href="#">Docs</a>
      <a href="#">Blog</a>
      <a href="https://github.com/Clavigers/abrasive-cli" class="gh" aria-label="GitHub">
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>
      <div class="nav-buttons">
        <a class="nav-btn nav-btn--signin" href="#" aria-label="Sign in">Sign in</a>
        <a class="nav-btn nav-btn--signup" href="#" aria-label="Sign up free">Sign up free</a>
      </div>
    </nav>
  </div>
</header>

<style>
  .topbar {
    position: sticky;
    top: 0;
    z-index: 50;
    width: 100%;
    background: rgba(10, 14, 20, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .topbar-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }
  .brand {
    display: flex;
    align-items: center;
    text-decoration: none;
  }
  .brand-img {
    height: 22px;
    width: auto;
    mix-blend-mode: screen;
    filter: contrast(1.6);
    opacity: 0.8;
    transition: opacity 0.15s;
  }
  .brand:hover .brand-img {
    opacity: 1;
  }
  .links {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }
  .links a {
    color: var(--muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: color 0.15s;
  }
  .links a:hover {
    color: var(--fg);
  }
  .gh {
    display: flex;
    align-items: center;
  }
  .nav-buttons {
    display: flex;
    align-items: center;
    gap: 0.5em;
    font-size: 14px;
    letter-spacing: -0.0175em;
  }
  .links a.nav-btn {
    border-radius: 0.25em;
    color: #fff;
    cursor: pointer;
    display: flex;
    font-weight: inherit;
    line-height: 2.2em;
    padding-left: 0.7625em;
    padding-right: 0.7625em;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.1s ease, box-shadow 0.1s ease;
  }
  .nav-btn--signin {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.18),
      0 0 0.1em 0.02em rgba(0, 0, 0, 0.05);
  }
  .nav-btn--signin:hover,
  .nav-btn--signin:focus {
    box-shadow:
      0 0 0 1px rgba(255, 255, 255, 0.85),
      0 0 0.1em 0.02em rgba(0, 0, 0, 0.05);
  }
  .links a.nav-btn--signup {
    background: rgb(11, 138, 15);
    color: #fff;
    font-weight: 500;
  }
  .links a.nav-btn--signup:hover,
  .links a.nav-btn--signup:focus {
    background: rgb(60, 175, 55);
    color: #fff;
  }
  @media (max-width: 600px) {
    .topbar-inner {
      padding: 0.6rem 1rem;
      gap: 1rem;
    }
    .links {
      gap: 1rem;
    }
    .links a {
      font-size: 0.82rem;
    }
    .nav-buttons {
      gap: 0.4em;
      font-size: 12px;
    }
  }
</style>
